@page "/purchaseorder/createpurchase"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject APiClient apiclient
@inject ILogger<SelectProductsForPurchase> logger
@inject PurchaseStateContainer purchaseState

@attribute [Authorize]

<h3>Create a Purchase</h3>

@* purchase is the object that will be edited thanks to the form *@
<EditForm Model="purchase" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.NameSurname" class="form-control" id="Name" />
                <label for="Name">Name and Surname</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.CustomerUserName" class="form-control" id="Name" />
                <label for="Name">UserName</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Street" class="form-control" id="DeliveryAddress" />
                <label for="DeliveryAddress">Delivery Address</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.City" class="form-control" id="Name" />
                <label for="Name">City</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.PostalCode" class="form-control" id="Name" />
                <label for="Name">Postal Code</label>
            </div>
        </div>
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@purchase.PaymentMethodId" id="PaymentMethod">
                    <option value="3">Bizum</option>
                    <option value="4">Credit Card</option>
                    <option value="5">PayPal</option>
                </InputSelect>
                <label for="PaymentMethod">Payment Method</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he wants to proceed to purchase the products*@
                <button class="btn btn-primary" type="submit" id="Submit">
                    Purchase your products
                </button>
            </div>
        </div>
    </div>
    <h4>Rental detail</h4>
    <p>
        <b>Total price:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyPurchaseProducts" id="ModifyProducts">
            Modify products
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Brand</th>
                    <th>Colour</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in purchase.PurchaseProducts)
                {
                    <tr id="ProductData_@item.Name">
                        <td>@item.Name</td>
                        <td>@item.Brand</td>
                        <td>@item.Colour</td> 
                        <td>@item.Quantity</td>
                        <td>@item.Price €</td>
                        <td>@(item.Price * item.Quantity) €</td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to rent*@
@if (DialogIsOpen)
{
    <Dialog Caption="Purchase prdocuts"
            Message="Do you want to proceed to purchase the selected products?"
            OnClose="@OnDialogClose"
            Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private bool DialogIsOpen;
    

    private decimal TotalCost =>
        purchase.PurchaseProducts.Sum(p => (decimal)p.Price * p.Quantity);
    
    private void ModifyPurchaseProducts()
    {
        navigation.NavigateTo("/purchaseorder/selectproductsforpurchase");
    }

    private PurchaseOrderForCreateDTO purchase => purchaseState.Purchase;
    
    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {

        DialogIsOpen = false;
        if (isOk)
        {
            // Process the data introduced by the user if they are valid
            if (purchase.PurchaseProducts.Count > 0)
            {
                try
                {
                    var purchased = await apiclient.CreatePurchaseOrderAsync(purchase);
                    purchaseState.PurchaseProcessed();
                    navigation.NavigateTo($"/purchaseord/detailpurchase/?PurchaseID={purchased.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }

            }
        }
    }
    protected override async Task OnInitializedAsync()
    {

        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null)
            {
                if (user.Identity is not null && user.Identity.IsAuthenticated)
                {
                    purchase.CustomerUserName = user.Identity.Name;
                }
            }
            purchase.NameSurname = purchase.NameSurname == null ? "" : purchase.NameSurname;
            purchase.Street = purchase.Street == null ? "" : purchase.Street;

        }
    }
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
}