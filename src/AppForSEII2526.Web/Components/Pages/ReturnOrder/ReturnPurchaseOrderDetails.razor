@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@page "/returnorder/details/{Id:int}"
@attribute [Authorize]

@inject APiClient apiclient
@inject ILogger<ReturnPurchaseOrderDetails> logger
@inject NavigationManager navigationManager

<h3>Return Purchase Order Details</h3>

<div class="container-fluid">

    @if (!string.IsNullOrEmpty(errors))
    {
        <div class="row alert alert-danger" role="alert">
            <div class="col">
                <p id="ErrorsShown">@errors</p>
                <button type="button"
                        class="btn btn-secondary"
                        id="BackToOrders"
                        @onclick="GoBackToOrders">
                    Back to orders
                </button>
            </div>
        </div>
    }

    @if (returnDetails == null && string.IsNullOrEmpty(errors))
    {
        <p>Loading return order details...</p>
    }
    else if (returnDetails != null)
    {
        
        <div class="row mb-4">
            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        Customer data
                    </div>
                    <div class="card-body">
                        <p><strong>Name:</strong> <span id="CustomerName">@returnDetails.CustomerName</span></p>
                        <p><strong>First surname:</strong> <span id="CustomerFirstSurname">@returnDetails.CustomerFirstSurname</span></p>
                        
                        <p><strong>Address:</strong> <span id="CustomerAddress">@returnDetails.CustomerAddress</span></p>
                        <p><strong>Telephone:</strong> <span id="CustomerTelephoneNumber">@returnDetails.CustomerTelephoneNumber</span></p>
                    </div>
                </div>
            </div>

            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        Returning information
                    </div>
                    <div class="card-body">
                        <p>
                            <strong>Returning option selected:</strong>
                            <span id="ReturningOptionSelected">@returnDetails.ReturningOptionSelected</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        
        <div class="row">
            <div class="col-12">
                <h4>Returned products</h4>

                @if (returnDetails.ReturnedProducts == null || !returnDetails.ReturnedProducts.Any())
                {
                    <p>No returned products found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfReturnedProducts">
                            <thead>
                                <tr>
                                    <th>Quantity</th>
                                    <th>Product</th>
                                    <th>Firm</th>
                                    <th>Warehouse location</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rp in returnDetails.ReturnedProducts)
                                {
                                    <tr id="@($"ReturnedProduct_{rp.ProductName.Replace(" ", "")}")">
                                        <td>@rp.Quantity</td>
                                        <td>@rp.ProductName</td>
                                        <td>@rp.BrandName</td>
                                        <td>@rp.WarehouseLocation</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }  

    private ReturnPurchaseOrderDTO? returnDetails;
    private string errors = "";

    private async Task LoadDetailsAsync()
    {
        try
        {
            
            returnDetails = await apiclient.GetReturnPurchaseOrderDetailsAsync(Id);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Error loading return purchase order details for Id {Id}", Id);

            if (ex.StatusCode == 404)
            {
                errors = $"No return purchase order found with ID {Id}.";
            }
            else
            {
                errors = "Error while loading the return order details.";
            }

            returnDetails = null;
        }
    }

    private void GoBackToOrders()
    {
        
        navigationManager.NavigateTo("/purchaseorders");
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDetailsAsync();
        await base.OnInitializedAsync();
    }
}
