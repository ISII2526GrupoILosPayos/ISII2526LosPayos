@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject APiClient apiclient
@inject ILogger<PurchaseProductForReturning> logger
@inject ReturnPurchaseOrderStateContainer returnPurchaseOrderStateContainer
@inject NavigationManager navigationManager

@page "/returnorder/purchaseproductforreturning"


<h3>Purchase Product For Returning</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">

                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">ProductName</span>
                        <input type="text"
                               id="inputProductName"
                               @bind=ProductName
                               class="form-control"
                               placeholder="ProductName"
                               aria-label="ProductName"
                               aria-describedby="basic-addon1" />
                    </div>
                </div>

                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Quantity</span>
                        <input type="number"
                               id="inputQuantity"
                               @bind=Quantity
                               class="form-control"
                               placeholder="Quantity"
                               aria-label="Quantity"
                               aria-describedby="basic-addon1" />
                    </div>
                </div>

                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">UserName</span>
                        <input type="text"
                               id="inputUserName"
                               @bind=UserName
                               class="form-control"
                               placeholder="UserName"
                               aria-label="UserName"
                               aria-describedby="basic-addon1" />
                    </div>
                </div>

                <div class="col">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick=@SearchPurchaseProductForReturning
                            id="purchaseProductForReturning">
                        Purchase Product For Returning
                    </button>
                </div>
            </div>

            <div class="row">
                @if (purchaseProductForReturn == null)
                {
                    <p>Loading purchaseProductsForReturning....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfReturnedProducts">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Brand</th>
                                    <th>Quantity Bought</th>
                                    <th>Warehouse</th>
                                    <th>Add</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var pp in purchaseProductForReturn)
                                {
                                    <tr id="ProductData_@pp.Name.Replace(" ", "")">
                                        <td>@pp.Name</td>
                                        <td>@pp.Brand</td>
                                        <td>@pp.Quantity</td>
                                        <td>@pp.Location</td>

                                        <td>
                                            <button class="btn btn-outline-secondary"
                                                    id="productToReturn_@pp.Name.Replace(" ", "")"
                                                    @onclick="@(() => AddProductToReturn(pp))">
                                                Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-2" hidden="@hideReturningCart">
            <div class="row">
                <h3>Return Cart</h3>
            </div>

            @foreach (var item in returnOrder.Items)
            {
                <div class="row">
                    <button type="button"
                            class="btn btn-light"
                            id="removeProduct_@item.ProductId"
                            @onclick="@(() => RemoveReturnItem(item))">
                        x Product @item.ProductId - Qty @item.Quantity
                    </button>
                </div>
            }

            <div class="row mt-2">
                <button type="button"
                        class="btn btn-primary"
                        id="continueReturnButton"
                        @onclick="GoToReturnDetails">
                    Continue with return
                </button>
            </div>
        </div>

    </div>

</div>

@code {
    // ▼▼▼ ESTADO BÁSICO ▼▼▼

    private ICollection<PurchaseProductForReturnDTO> purchaseProductForReturn;
    private string errors = "";

    private bool hideErrors => errors.Length == 0;

    // Alias al DTO que se enviará en el POST
    private ReturnPurchaseOrderForCreateDTO returnOrder =>
        returnPurchaseOrderStateContainer.ReturnOrder;

    // Mostrar u ocultar el carrito de devolución
    private bool hideReturningCart => returnOrder.Items.Count == 0;

    // ▼▼▼ BACKING FIELDS PARA LOS FILTROS ▼▼▼

    private string productName;
    private int quantity;
    private string userName;

    // Propiedad para el ProductName (para poder enganchar lógica en el cambio)
    private string ProductName
    {
        get => productName;
        set
        {
            if (productName != value)
            {
                productName = value;

                // reseteamos items de devolución
                returnPurchaseOrderStateContainer.ResetAfterProcessing();

                // volvemos a poner el username si ya lo tenemos
                if (!string.IsNullOrWhiteSpace(userName))
                    returnPurchaseOrderStateContainer.SetCustomerUserName(userName);
            }
        }
    }

    private int Quantity
    {
        get => quantity;
        set
        {
            if (quantity != value)
            {
                quantity = value;

                returnPurchaseOrderStateContainer.ResetAfterProcessing();

                if (!string.IsNullOrWhiteSpace(userName))
                    returnPurchaseOrderStateContainer.SetCustomerUserName(userName);
            }
        }
    }


    // Propiedad para UserName (ya la tenías, le añadimos ResetAfterProcessing)
    private string UserName
    {
        get => userName;
        set
        {
            if (userName != value)
            {
                userName = value;

                // 1º: vaciamos items de devolución
                returnPurchaseOrderStateContainer.ResetAfterProcessing();

                // 2º: y AHORA sí metemos el username correcto en el DTO nuevo
                returnPurchaseOrderStateContainer.SetCustomerUserName(userName);
            }
        }
    }


    // ▼▼▼ LÓGICA DE CARRITO Y NAVEGACIÓN ▼▼▼

    // Añadir un producto al “carrito de devolución”
    private void AddProductToReturn(PurchaseProductForReturnDTO product)
    {
        // De momento usamos cantidad = 1 y reason vacío;
        // se rellena luego en la pantalla de detalles
        returnPurchaseOrderStateContainer.AddProductForReturn(
            product,
            quantity: 1,
            reason: ""
        );
    }

    // Quitar un item del carrito
    private void RemoveReturnItem(ReturnItemForCreateDTO item)
    {
        returnPurchaseOrderStateContainer.RemoveItem(item);
    }

    // Ir al siguiente paso del caso de uso (rellenar razón, método de devolución, rating, etc.)
    private void GoToReturnDetails()
    {
        navigationManager.NavigateTo("/returnorder/createreturnpurchaseorder");
    }

    // ▼▼▼ BÚSQUEDA EN LA API ▼▼▼

    public async void SearchPurchaseProductForReturning()
    {
        // Validaciones previas simples (equivalente a las de fechas en el ejemplo de películas)
        if (string.IsNullOrWhiteSpace(UserName))
        {
            errors = "UserName is required.";
            return;
        }

        if (Quantity < 0)
        {
            errors = "Quantity must be 0 or greater.";
            return;
        }

        try
        {
            purchaseProductForReturn =
                await apiclient.GetPurchasedProductsForReturningAsync(
                    productName,
                    userName,
                    quantity,
                    CancellationToken.None
                );

            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }

        StateHasChanged();
    }

    // ▼▼▼ INICIALIZACIÓN ▼▼▼

    protected override Task OnInitializedAsync()
    {
        // Valores iniciales por defecto (igual idea que fechas From/To en películas)
        UserName = "pauUser";  // usamos la PROPIEDAD, así sincroniza el StateContainer
        ProductName = "";
        Quantity = 0;

        // Llamada inicial, igual que SearchMovies() en el ejemplo
        SearchPurchaseProductForReturning();

        return base.OnInitializedAsync();
    }
}
