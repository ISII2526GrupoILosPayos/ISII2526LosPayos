@using AppForSEII2526.Web.API
@inject APiClient apiclient
@inject ILogger<PurchaseProductForReturning> logger
@inject ReturnPurchaseOrderStateContainer returnPurchaseOrderStateContainer
@page "/returnorder/purchaseproductforreturning"


<h3>Purchase Product For Returning</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
               

                <div class="col">
                    <div class= "input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">ProductName</span>
                        <input type="text" id="inputProductName" @bind=productName class="form-control" placeholder="ProductName" aria-label="ProductName" aria-describedby="basic-addon1">
                    </div>
                </div>

                <div class="col">
                    <div class= "input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Quantity</span>
                        <input type="number" id="inputQuantity" @bind=quantity class="form-control" placeholder="Quantity" aria-label="Quantity" aria-describedby="basic-addon1">
                    </div>
                </div>

                <div class="col">
                    <div class= "input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">UserName</span>
                        <input type="text" id="inputUserName" @bind=userName class="form-control" placeholder="UserName" aria-label="UserName" aria-describedby="basic-addon1">
                    </div>
                </div>



                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchPurchaseProductForReturning id="purchaeProductForReturning">Purchase Product For Returning </button>
                </div>
            </div>
            <div class="row">
                @if (purchaseProductForReturn == null)
                {
                    <p>Loading purchaseProductsForReturning....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfReturnedProducts">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Brand</th>
                                    <th>Quantity Bought</th>
                                    <th>Warehouse</th>
                                    <th>Add</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var pp in purchaseProductForReturn)
                                {
                                    <tr id="ProductData_@pp.Name.Replace(" ", "")">
                                        <td>@pp.Name</td>
                                        <td>@pp.Brand</td>
                                        <td>@pp.Quantity</td>
                                        <td>@pp.Location</td>

                                        <td>
                                            <button class="btn btn-outline-secondary"
                                                    id="productToReturn_@pp.Name.Replace(" ", "")"
                                                    @onclick="@(() => AddProductToReturn(pp))">
                                                Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>

                }
            </div>
        </div>
        <div class="col-2">
            <p>here i will show the renting cart</p>
        </div>

    </div>

</div>

@code {
    private ICollection<PurchaseProductForReturnDTO> purchaseProductForReturn;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string productName { get; set; }
    private int quantity { get; set; }
    // Alias al DTO que se enviará en el POST
    private ReturnPurchaseOrderForCreateDTO returnOrder =>
        returnPurchaseOrderStateContainer.ReturnOrder;

    // Para ocultar/mostrar el “carrito de devolución” si quieres usarlo luego
    private bool hiddenReturningCart = true;


    private string userName;

    private string UserName
    {
        get => userName;
        set
        {
            if (userName != value)
            {
                userName = value;

                // sincroniza el StateContainer cuando cambie el usuario
                returnPurchaseOrderStateContainer.SetCustomerUserName(userName);
            }
        }
    }


    // Añadir un producto al “carrito de devolución”
    private void AddProductToReturn(PurchaseProductForReturnDTO product)
    {
        // De momento usamos cantidad = 1 y reason vacío;
        // luego lo refinas en la pantalla siguiente
        returnPurchaseOrderStateContainer.AddProductForReturn(product, quantity: 1, reason: "");
        hiddenReturningCart = false;
    }

    // Quitar un item del carrito
    private void RemoveReturnItem(ReturnItemForCreateDTO item)
    {
        returnPurchaseOrderStateContainer.RemoveItem(item);

        if (returnOrder.Items.Count == 0)
            hiddenReturningCart = true;
    }


    public async void SearchPurchaseProductForReturning()
    {

        if (string.IsNullOrWhiteSpace(UserName))
        {
            errors = "UserName is required.";
            return;
        }

        if (quantity < 0)
        {
            errors = "Quantity must be 0 or greater.";
            return;
        }


        try
        {
            purchaseProductForReturn =
                await apiclient.GetPurchasedProductsForReturningAsync(
                    productName,
                    userName,
                    quantity,
                    CancellationToken.None
                );
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }

        StateHasChanged();
    }



    protected override Task OnInitializedAsync()
    {
        // Valores iniciales por defecto
        userName = "pauUser";   // IMPORTANTE: aquí debe ir el UserName real de BD
        productName = "";
        quantity = 0;

        // Sincronizar el StateContainer con este usuario inicial
        returnPurchaseOrderStateContainer.SetCustomerUserName(userName);

        // Llamada inicial, igual idea que SearchMovies() en el ejemplo
        SearchPurchaseProductForReturning();

        return base.OnInitializedAsync();
    }



}
