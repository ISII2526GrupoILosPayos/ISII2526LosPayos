@page "/returnorder/createreturnpurchaseorder"

@using AppForSEII2526.Web.API
@using AppForSEII2526.Web.Components.Account.Shared
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using System.Text

@inject APiClient apiClient
@inject ReturnPurchaseOrderStateContainer returnPurchaseOrderStateContainer
@inject NavigationManager Navigation

@attribute [Authorize]

<h3>Return products of a purchase</h3>

<EditForm Model="returnOrder"
          OnValidSubmit="OnSaveReturn"
          OnInvalidSubmit="HandleInvalidSubmit">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Datos del cliente (solo lectura: vienen del ApplicationUser vía API) -->
    <div class="row g-2 mb-3">
        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerName" readonly />
                <label>Customer name</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerSurname" readonly />
                <label>Customer surname</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerAddress" readonly />
                <label>Address</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerTelephone" readonly />
                <label>Telephone</label>
            </div>
        </div>
    </div>

    <!-- Opciones de devolución -->
    <div class="row g-2 mb-3">
        <div class="col-md">
            <div class="form-floating">
                <InputSelect class="form-select" id="ReturningOptionSelected" @bind-Value="returnOrder.ReturningOptionSelected">
                    <option value="">-- Select returning option --</option>
                    <option value="CreditCard">Credit Card</option>
                    <option value="PayPal">PayPal</option>
                    <option value="Cash">Cash</option>
                    <option value="Bizum">Bizum</option>
                </InputSelect>
                <label for="ReturningOptionSelected">Returning money option (mandatory)</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <InputNumber @bind-Value="returnOrder.Rating" class="form-control" id="Rating" TValue="int?" />
                <label for="Rating">Rating for delivery system (1–5, optional)</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <button class="btn btn-primary w-100" type="submit" id="SubmitReturnOrder" disabled="@(returnOrder.Items.Count == 0)">
                    Save return
                </button>
            </div>
        </div>
    </div>

</EditForm>

<h4>Products selected to be returned</h4>

@if (!returnOrder.Items.Any())
{
    <p>No products selected yet. Please go back and add products.</p>
}
else
{
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfReturnItems">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Brand</th>
                    <th>Brand location</th>
                    <th>Quantity</th>
                    <th>Reason for returning</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in returnOrder.Items)
                {
                    <tr id="@($"ReturnItem_{item.ProductId}_{item.PurchaseOrderId}")">
                        <td>@item.ProductName</td>
                        <td>@item.BrandName</td>
                        <td>@item.BrandLocation</td>
                        <td>
                            <InputNumber @bind-Value="item.Quantity" class="form-control" TValue="int" />
                        </td>
                        <td>
                            <InputText class="form-control" @bind-Value="item.Reason" id="@($"reason_{item.ProductId}_{item.PurchaseOrderId}")" />
                        </td>
                        <td>
                            <button class="btn btn-outline-danger btn-sm" type="button" @onclick="@(() => RemoveReturnItem(item))">
                                Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <p class="mt-3">
        <button class="btn btn-outline-secondary" type="button" id="ModifyProducts" @onclick="GoBackToSelection">
            Modify selected products
        </button>
    </p>
}

@if (infoDialogOpen)
{
    <Dialog Caption="Information"
            Message="@infoDialogMessage"
            OnClose="OnInfoDialogClose"
            Type="Dialog.Category.Okay">
    </Dialog>
}

@code
{
    // ================= STATE =================
    private ReturnPurchaseOrderForCreateDTO returnOrder => returnPurchaseOrderStateContainer.ReturnOrder;

    private string customerName = "";
    private string customerSurname = "";
    private string customerAddress = "";
    private string customerTelephone = "";

    private bool infoDialogOpen = false;
    private string infoDialogMessage = "";

    // ================= ACCIONES DE UI =================
    private void GoBackToSelection()
    {
        Navigation.NavigateTo("/returnorder/purchaseproductforreturning");
    }

    private void RemoveReturnItem(ReturnItemForCreateDTO item)
    {
        returnPurchaseOrderStateContainer.RemoveItem(item);
    }

    // Se ejecuta cuando el formulario pasa todas las validaciones de DataAnnotations
    private async Task OnSaveReturn()
    {
        // Seguridad: al menos un producto
        if (!returnOrder.Items.Any())
        {
            infoDialogMessage = "You must select at least one product to return.";
            infoDialogOpen = true;
            return;
        }

        try
        {
            apiClient.ReadResponseAsString = true;

            var created = await apiClient.CreateReturnPurchaseOrderAsync(returnOrder);

            returnPurchaseOrderStateContainer.ResetAfterProcessing();
            Navigation.NavigateTo($"/returnorder/details/{created.Id}");
        }
        catch (ApiException<ValidationProblemDetails> apiEx)
        {
            var messages = new List<string>();

            if (apiEx.Result?.Errors != null)
            {
                foreach (var kvp in apiEx.Result.Errors)
                {
                    var field = kvp.Key;
                    var fieldErrors = string.Join(", ", kvp.Value);
                    messages.Add($"{field}: {fieldErrors}");
                }
            }

            infoDialogMessage = messages.Any()
                ? "VALIDATION ERRORS:\n" + string.Join("\n", messages)
                : $"Validation error ({apiEx.StatusCode}): " + (apiEx.Result?.Title ?? apiEx.Message);

            infoDialogOpen = true;
        }
        catch (ApiException ex)
        {
            infoDialogMessage = $"API ERROR ({ex.StatusCode}):\n{ex.Response}";
            infoDialogOpen = true;
        }
    }

    // Cuando FALLA la validación del EditForm
    private void HandleInvalidSubmit(EditContext editContext)
    {
        var messages = editContext.GetValidationMessages();
        infoDialogMessage = "Validation errors: " + string.Join(" | ", messages);
        infoDialogOpen = true;

        Console.WriteLine("Validation errors:");
        foreach (var m in messages) Console.WriteLine(m);
    }

    private Task OnInfoDialogClose()
    {
        infoDialogOpen = false;
        return Task.CompletedTask;
    }

    // ================= INICIALIZACIÓN =================
    protected override async Task OnInitializedAsync()
    {
        if (!returnOrder.Items.Any())
        {
            Navigation.NavigateTo("/returnorder/purchaseproductforreturning");
            return;
        }

        // Si todavía no tenemos rellenos los datos del cliente en el StateContainer,
        // los pedimos al API a partir del PurchaseOrderId del primer ítem.
        if (string.IsNullOrWhiteSpace(returnOrder.CustomerName) 
            || string.IsNullOrWhiteSpace(returnOrder.CustomerSurname)
        || string.IsNullOrWhiteSpace(returnOrder.CustomerAddress))
        {
            // Cogemos el primer pedido asociado a los ítems devueltos
            var orderId = returnOrder.Items.First().PurchaseOrderId;

            // Llamamos al API para obtener los datos completos del pedido
            var order = await apiClient.GetPurchaseOrderAsync(orderId);

            // Construimos una dirección "bonita" con los campos del DTO
            var fullAddress = $"{order.Street}, {order.PostalCode} {order.City}";
            var phone = "65432451";

            // Guardamos TODO en el StateContainer
            returnPurchaseOrderStateContainer.SetCustomerData(
                userName: returnOrder.CustomerUserName, // ya lo tenías en el modelo
                name: order.CustomerName,
                surname: order.CustomerSurname,
                address: fullAddress,
                telephone: phone // aquí pon lo que tengas; si no hay teléfono en el DTO, lo dejamos vacío
            );
        }

        // Ahora ya podemos leer del modelo para pintar en la UI
        customerName = returnOrder.CustomerName;
        customerSurname = returnOrder.CustomerSurname;
        customerAddress = returnOrder.CustomerAddress;
        customerTelephone = returnOrder.CustomerTelephone;

        await base.OnInitializedAsync();
    }
}
