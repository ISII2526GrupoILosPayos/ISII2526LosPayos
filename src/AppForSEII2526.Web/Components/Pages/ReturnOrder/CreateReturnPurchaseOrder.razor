@page "/returnorder/createreturnpurchaseorder"

@using AppForSEII2526.Web.API
@using AppForSEII2526.Web.Components.Account.Shared@* Para Dialog *@
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations

@inject APiClient apiClient
@inject ReturnPurchaseOrderStateContainer returnPurchaseOrderStateContainer
@inject NavigationManager Navigation

@attribute [Authorize]

<h3>Return products of a purchase</h3>

<EditForm Model="returnOrder" OnValidSubmit="OpenConfirmDialog">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Datos del cliente (solo lectura: vienen del ApplicationUser vía API) -->
    <div class="row g-2 mb-3">
        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerName" readonly />
                <label>Customer name</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerAddress" readonly />
                <label>Address</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                <input class="form-control" value="@customerTelephone" readonly />
                <label>Telephone</label>
            </div>
        </div>
    </div>

    <!-- Opciones de devolución (paso 5 del UC) -->
    <div class="row g-2 mb-3">
        <div class="col-md">
            <div class="form-floating">
                <InputSelect class="form-select"
                             id="ReturningOptionSelected"
                             @bind-Value="returnOrder.ReturningOptionSelected">
                    <option value="">-- Select returning option --</option>
                    @* IMPORTANTE: los values deben coincidir con los nombres de las clases
                       de métodos de pago en el API: "CreditCard", "PayPal", "Cash", "Bizum"... *@
                    <option value="CreditCard">Credit Card</option>
                    <option value="PayPal">PayPal</option>
                    <option value="Cash">Cash</option>
                    <option value="Bizum">Bizum</option>

                </InputSelect>
                <label for="ReturningOptionSelected">Returning money option (mandatory)</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <InputNumber int? class="form-control"
                             id="Rating"
                             @bind-Value="returnOrder.Rating" />
                <label for="Rating">Rating for delivery system (1–5, optional)</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <button class="btn btn-primary w-100"
                        type="submit"
                        id="SubmitReturnOrder"
                        disabled="@(returnOrder.Items.Count == 0)">
                    Save return
                </button>
            </div>
        </div>
    </div>
</EditForm>

<h4>Products selected to be returned</h4>

@if (!returnOrder.Items.Any())
{
    <p>No products selected yet. Please go back and add products.</p>
}
else
{
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfReturnItems">
            <thead>
                <tr>
                    <th>ProductId</th>
                    <th>OrderId</th>
                    <th>Quantity</th>
                    <th>Reason for returning</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in returnOrder.Items)
                {
                    <tr id="@($"ReturnItem_{item.ProductId}_{item.PurchaseOrderId}")">
                        <td>@item.ProductId</td>
                        <td>@item.PurchaseOrderId</td>
                        <td>
                            <InputNumber int class="form-control"
                                         @bind-Value="item.Quantity" />
                        </td>
                        <td>
                            <InputText class="form-control"
                                       @bind-Value="item.Reason"
                                       id="@($"reason_{item.ProductId}_{item.PurchaseOrderId}")" />
                        </td>
                        <td>
                            <button class="btn btn-outline-danger btn-sm"
                                    type="button"
                                    @onclick="@(() => RemoveReturnItem(item))">
                                Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <p class="mt-3">
        <button class="btn btn-outline-secondary"
                type="button"
                id="ModifyProducts"
                @onclick="GoBackToSelection">
            Modify selected products
        </button>
    </p>
}

@if (confirmDialogOpen)
{
    <Dialog Caption="Confirm return"
            Message="Do you want to proceed with the return of the selected products?"
            OnClose="OnConfirmDialogClose"
            Type="Dialog.Category.SaveNot">
    </Dialog>
}

@if (infoDialogOpen)
{
    <Dialog Caption="Information"
            Message="@infoDialogMessage"
            OnClose="OnInfoDialogClose"
            Type="Dialog.Category.Okay">
    </Dialog>
}

@code {
    // ================= STATE =================

    // Alias al DTO del StateContainer
    private ReturnPurchaseOrderForCreateDTO returnOrder =>
        returnPurchaseOrderStateContainer.ReturnOrder;

    // Datos del cliente para mostrar (rellenados al cargar la página)
    private string customerName = "";
    private string customerAddress = "";
    private string customerTelephone = "";

    // Diálogos
    private bool confirmDialogOpen = false;
    private bool infoDialogOpen = false;
    private string infoDialogMessage = "";

    // ================= ACCIONES DE UI =================

    private void GoBackToSelection()
    {
        Navigation.NavigateTo("/returnorder/purchaseproductforreturning");
    }

    private void RemoveReturnItem(ReturnItemForCreateDTO item)
    {
        returnPurchaseOrderStateContainer.RemoveItem(item);
    }

    private void OpenConfirmDialog()
    {
        // Solo tiene sentido confirmar si hay items
        if (!returnOrder.Items.Any())
        {
            infoDialogMessage = "You must select at least one product to return.";
            infoDialogOpen = true;
            return;
        }

        confirmDialogOpen = true;
    }

    private async Task OnConfirmDialogClose(bool isOk)
    {
        confirmDialogOpen = false;
        if (!isOk)
            return;

        try
        {
            // Llamada al API: CreateReturnPurchaseOrder
            var created = await apiClient.CreateReturnPurchaseOrderAsync(returnOrder);

            // Limpiamos el estado para una futura devolución
            returnPurchaseOrderStateContainer.ResetAfterProcessing();

            // Por ahora mostramos mensaje de éxito.
            // Más adelante, cuando tengas la página de detalle, puedes navegar a ella.
            infoDialogMessage = "Return processed successfully.";
            infoDialogOpen = true;

            // Ejemplo cuando tengas detalle:
            // Navigation.NavigateTo($"/returnorder/detail?id={created.Id}");
        }
        catch (ApiException<ValidationProblemDetails> apiEx)
        {
            // Errores de validación (400)
            var messages = new List<string>();

            if (apiEx.Result?.Errors != null)
            {
                foreach (var kvp in apiEx.Result.Errors)
                    messages.AddRange(kvp.Value);
            }

            infoDialogMessage = messages.Any()
                ? string.Join(" (*) ", messages)
                : "Error while processing your request. Please, check the data and try again.";

            infoDialogOpen = true;
        }
        catch (ApiException ex)
        {
            // Otros errores de API
            infoDialogMessage = "Error while connecting to the system. Please, try again later.";
            infoDialogOpen = true;
        }
    }

    private Task OnInfoDialogClose()
    {
        infoDialogOpen = false;
        return Task.CompletedTask;
    }

    // ================= INICIALIZACIÓN =================

    protected override async Task OnInitializedAsync()
    {
        // Seguridad mínima: si no hay ningún producto en el carrito, volver a la selección
        if (!returnOrder.Items.Any())
        {
            Navigation.NavigateTo("/returnorder/purchaseproductforreturning");
            return;
        }

        // Si ya tienes el CustomerUserName en el state, podrías usarlo
        // para pedir los datos del cliente a tu API (Name, Address, Phone...)
        // De momento, mostramos el userName como "name" para no romper nada.
        customerName = returnOrder.CustomerUserName;
        customerAddress = "(address will come from API)";
        customerTelephone = "(telephone from API)";

        await base.OnInitializedAsync();
    }
}
